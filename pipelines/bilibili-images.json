{
  "id": "bilibili-images",
  "platform": "bilibili",
  "mode": "images",
  "name": "哔哩哔哩 · 图文",
  "steps": [
    {
      "id": "title",
      "name": "标题生成",
      "type": "title",
      "needs": [],
      "promptTemplate": "bilibili/images/title.md",
      "humanGate": true,
      "defaultProvider": "cli-claude"
    },
    {
      "id": "content",
      "name": "图文内容生成",
      "type": "content",
      "needs": [
        "title"
      ],
      "promptTemplate": "bilibili/images/content.md",
      "defaultProvider": "cli-claude"
    },
    {
      "use": "cover",
      "name": "首图生成",
      "promptTemplate": "bilibili/images/cover.md",
      "aspects": [
        "1:1",
        "3:4",
        "9:16",
        "16:9"
      ]
    },
    "image-prompts",
    {
      "use": "batch-images",
      "aspects": [
        "1:1",
        "3:4",
        "9:16",
        "16:9"
      ]
    },
    {
      "use": "image-to-video",
      "when": {
        "imageGen": "real",
        "videoGen": "real"
      },
      "aspects": [
        "1:1",
        "3:4",
        "9:16",
        "16:9"
      ]
    },
    "review"
  ],
  "notes": [
    "图文动态配图最多 9 张，首图决定点击，信息最强的放第一张",
    "正文口语化、有梗但不堆梗，B 站用户反感营销腔",
    "话题（#话题#）选 1-3 个精准的，蹭不相关热门话题会被限流",
    "图片统一风格，文字大小保证手机端可读",
    "不要出现站外水印、二维码、引流信息"
  ],
  "options": [
    {
      "id": "aspect",
      "default": "1:1",
      "aspects": [
        "1:1",
        "3:4",
        "9:16",
        "16:9"
      ]
    },
    {
      "id": "titleMaxLen",
      "label": "标题字数上限",
      "type": "number",
      "default": "30",
      "min": 8,
      "max": 80
    },
    {
      "id": "contentLen",
      "label": "正文字数",
      "type": "number",
      "default": "600",
      "min": 80,
      "max": 4000,
      "step": 50
    },
    {
      "id": "imageCount",
      "label": "图片数量",
      "type": "number",
      "default": "6",
      "min": 3,
      "max": 12,
      "hint": "配图生成多少张"
    },
    "imageGen",
    {
      "id": "videoGen",
      "label": "图生视频",
      "default": "none",
      "choices": [
        {
          "value": "none",
          "label": "不生成视频"
        },
        {
          "value": "real",
          "label": "图片转动态视频（需开启真实出图+视频API）"
        }
      ]
    }
  ]
}
