# ============================================================
#  引擎密钥 / CLI 配置  ——  复制本文件为 .env 后填写（.env 不会被提交）
#  填好后重启服务（pnpm start）即生效；留空的项对应引擎保持「停用」。
#  也可以不用本文件，改在网页「引擎管理」页里手动填 key。
# ============================================================

# ---------- CLI（走订阅，包月不额外计费）----------
# 值 = 该 CLI 在你电脑上的命令名（在终端能直接运行的那个）。
# 装在 PATH 里就直接写命令名；否则写绝对路径，如 C:\tools\claude.exe
AMP_CLI_CLAUDE=claude
# Antigravity CLI（agy）：建议写绝对路径（后台服务进程的 PATH 可能比安装时旧，找不到裸命令名）
AMP_CLI_GEMINI=C:\Users\<你的用户名>\AppData\Local\agy\bin\agy.exe
AMP_CLI_CODEX=codex
AMP_CLI_GROK=grok
AMP_CLI_KIMI=kimi

# ---------- API Key（按量计费）----------
# xAI Grok（你已充值）：用于 文本/看图/出图。https://console.x.ai
GROK_API_KEY=

# DeepSeek（你已充值）：便宜，推荐用于评审打分。https://platform.deepseek.com
DEEPSEEK_API_KEY=

# Kimi / Moonshot（你已充值）：文本 + 看图。https://platform.moonshot.cn
KIMI_API_KEY=

# 火山方舟（即梦/Seedream 出图，中文封面最佳，支付宝可充）。https://console.volcengine.com/ark
ARK_API_KEY=

# 【MV 批量出图专用，可选】MV 模块「真实出图」按提示词逐张生成时用的出图引擎。
# 留空则自动复用上面的 ARK_API_KEY（走即梦）；想用单独账号/模型时才填这里。
MV_IMAGE_API_KEY=
# MV_IMAGE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# MV_IMAGE_MODEL=doubao-seedream-4-0-250828

# 【图生视频，可选】把生成的图片转成动态视频片段（即梦视频/Seedance，异步）。
# 填了才启用「图生视频」节点；模型 id 以你火山控制台开通的视频模型为准。
MV_VIDEO_API_KEY=
# MV_VIDEO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# MV_VIDEO_MODEL=doubao-seedance-1-0-lite-i2v-250428

# OpenAI（如果以后能充值；用于 gpt-image-1 出图）
OPENAI_API_KEY=
